    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {\r",
              "    const response = pm.response.json();\r",
              "    \r",
              "    pm.environment.set(\"access_token\", response.access);\r",
              "    pm.environment.set(\"refresh_token\", response.refresh);\r",
              "    \r",
              "    console.log(\"Токены сохранены!\");\r",
              "    console.log(\"Access Token:\", response.access.substring(0, 50) + \"...\");\r",
              "} else {\r",
              "    console.log(\"Ошибка входа:\", pm.response.text());\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
