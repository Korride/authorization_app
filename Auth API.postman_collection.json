    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 205) {\r",
              "    pm.environment.unset(\"access_token\");\r",
              "    pm.environment.unset(\"refresh_token\");\r",
              "    console.log(\"Выход выполнен, токены удалены\");\r",
              "} else {\r",
              "    console.log(\"Ошибка выхода\");\r",
              "}"
